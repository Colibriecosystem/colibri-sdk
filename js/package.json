{
  "name": "@colibri/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for the Colibri Local API — read the order book, stream trades, and trade from a widget or bot.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "example:rest": "tsx examples/basic-rest.ts",
    "example:book": "tsx examples/orderbook-stream.ts",
    "example:trades": "tsx examples/live-trades.ts"
  },
  "keywords": ["colibri", "trading", "orderbook", "websocket", "crypto", "scalping"],
  "license": "MIT",
  "engines": { "node": ">=20" },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
